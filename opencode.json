{
  "$schema": "https://opencode.ai/config.json",

  "agent": {
    "conductor":  { "model": "openrouter/openai/gpt-5.6-luna" },
    "reviewer":   { "model": "openrouter/openai/gpt-5.6-luna" },
    "committer":  { "model": "openrouter/deepseek/deepseek-v4-flash" },
    "escalate1":  { "model": "openrouter/openai/gpt-5.6-luna" },
    "escalate2":  { "model": "openrouter/openai/gpt-5.6-terra" },
    "build":      { "model": "openrouter/deepseek/deepseek-v4-flash" },
    "plan":       { "model": "openrouter/openai/gpt-5.6-luna" },
    "explore":    { "model": "openrouter/deepseek/deepseek-v4-flash" },
    "general":    { "model": "openrouter/deepseek/deepseek-v4-flash" },
    "verifier":   { "model": "openrouter/deepseek/deepseek-v4-flash" }
  },

  "provider": {
    "openrouter": {
      "models": {
        "openai/gpt-5.6-luna": {
          "options": {
            "reasoningEffort": "max"
          }
        },
        "openai/gpt-5.6-terra": {
          "options": {
            "reasoningEffort": "max"
          }
        }
      }
    }
  }
}
